# Provenance of the bundled seed snapshot in this wheel.
#
# Format:
#   source_url=<git-remote-URL of the seed repo this snapshot came from>
#   source_sha=<full git SHA at the time scripts/sync_bundled_seed.sh ran>
#   source_branch=<branch ref the SHA belongs to>
#
# The CI guard at .github/workflows/check-bundled-seed.yml verifies that the
# files in this directory match `git archive --format=tar <source_url> <source_sha>`
# of the canonical seed.
#
# Forks: change source_url + source_sha to point at your fork. CI guard will
# then verify against your fork instead. The Agnes binary's resolution chain
# is unaffected (operator-configured Initial Workspace Template ALWAYS wins
# over the bundled snapshot at runtime).
source_url=https://github.com/keboola/agnes-infra-template
source_sha=4171aa8919430dba6798c98d948a275f64828bec
source_branch=main
