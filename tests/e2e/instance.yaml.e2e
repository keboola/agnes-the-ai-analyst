# instance.yaml.e2e — config used inside the docker-compose E2E env.
#
# Mirrors instance.yaml.example but with cloud-chat enabled and pointed
# at an E2B-backed sandbox. The real E2B smoke (which actually spawns
# microVMs) is gated separately by AGNES_E2E_E2B=1 on the host so the
# default e2e run doesn't burn billable sandbox minutes.

config_version: 1

instance:
  name: "Agnes E2E"
  subtitle: "End-to-end test instance"
  copyright: "E2E"
  brand: "Agnes"

data_source:
  type: "csv"

chat:
  enabled: true
  provider: e2b
  # Operator builds this against their own E2B account via
  # `e2b template build` in app/initial_workspace_default/e2b-template/.
  e2b_template_id: "agnes-chat"
  e2b_workspace_max_bytes: 104857600  # 100 MB
  e2b_kill_on_ws_disconnect: true
  concurrency_per_user: 3
  idle_ttl_seconds: 1800
  per_tool_call_seconds: 90
  per_session_bq_scan_bytes: 21474836480
  daily_anthropic_spend_usd: 20.0
  max_session_seconds: 14400
  max_session_tokens: 200000
  rate_messages_per_hour: 100
  tool_calls_per_turn_budget: 50
  marketplace_sha_debounce_seconds: 300
