# instance.yaml.e2e — config used inside the docker-compose E2E env.
#
# Mirrors instance.yaml.example but with cloud-chat enabled and the
# sandbox uid pinned to 1001 (the `agnes-sandbox` user created in
# Dockerfile.e2e). Everything else is minimal: a local DuckDB warehouse,
# no real data source connectors, no Slack credentials.

config_version: 1

instance:
  name: "Agnes E2E"
  subtitle: "End-to-end test instance"
  copyright: "E2E"
  brand: "Agnes"

data_source:
  type: "csv"

chat:
  enabled: true
  require_isolation: true
  sandbox_uid: 1001
  concurrency_per_user: 3
  idle_ttl_seconds: 1800
  per_tool_call_seconds: 90
  per_session_bq_scan_bytes: 21474836480
  daily_anthropic_spend_usd: 20.0
  max_session_seconds: 14400
  max_session_tokens: 200000
  rate_messages_per_hour: 100
  tool_calls_per_turn_budget: 50
  marketplace_sha_debounce_seconds: 300
