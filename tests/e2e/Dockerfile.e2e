# Dockerfile.e2e — Linux Agnes server for the cloud-chat E2E suite.
#
# Under the E2B-provider model the in-container isolation stack (nsjail,
# iptables, dedicated sandbox uid) is gone — chat sandboxes run in E2B's
# cloud microVMs, not on this host. All this image needs is the FastAPI
# app + sample data; no NET_ADMIN, no host uid mapping, no nsjail build.
#
# The container still exists rather than running uvicorn naked from the
# tests because the sample-data loader and DuckDB init need a stable
# /data layout and the conftest fixture spins it up via docker-compose
# for parity with production startup ordering.
#
# Python version + installer mirror the production Dockerfile: 3.13-slim
# and uv. uv is load-bearing, not a speed-up — the kbcstorage→urllib3<2.0
# cap conflicts with our urllib3>=2.7.0 security pin and is only resolvable
# through `[tool.uv] override-dependencies` in pyproject.toml; plain pip
# dies with ResolutionImpossible.

FROM python:3.13-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Provision the venv with third-party deps first so the layer caches
# across source edits. README.md must ride along — pyproject's
# `readme = "README.md"` makes metadata generation fail without it.
# `-r pyproject.toml` installs only the dependencies (the project itself
# is linked editable after COPY below, once its source exists).
COPY pyproject.toml README.md ./
RUN uv venv /opt/venv \
    && VIRTUAL_ENV=/opt/venv uv pip install -r pyproject.toml --extra dev --extra server

# Copy the rest of the source. `.dockerignore` should keep .venv and
# .git out — the compose file uses repo root as the build context.
COPY . .

# Link the package itself (deps are already in the cached layer above).
RUN VIRTUAL_ENV=/opt/venv uv pip install --no-deps -e .

# /data is the runtime data dir referenced by ChatRepository,
# WorkdirManager, the analytics warehouse, and the sample-data loader.
RUN mkdir -p /data/state /data/analytics /data/marketplaces /data/users

EXPOSE 8000

CMD ["/app/tests/e2e/start.sh"]
